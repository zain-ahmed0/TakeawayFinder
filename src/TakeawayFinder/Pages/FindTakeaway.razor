@page "/find-takeaway"

<PageTitle>Find Takeaway</PageTitle>

<h1>Find Takeaway</h1>

@if (!IsDeployedOnGitHubPages)
{
    <div class="card mb-4">
        <div class="card-body">
            <EditForm Model="SearchModel" OnValidSubmit="SearchRestaurantsAsync">
                <DataAnnotationsValidator/>
                <div class="row g-3 align-items-end">
                    <div class="col-md-6 col-lg-4">
                        <label for="postcode" class="form-label">Enter Postcode:</label>
                        <InputText
                            id="postcode"
                            @bind-Value="SearchModel!.Postcode"
                            class="form-control"
                            autocomplete="off"
                            maxlength="8"
                            placeholder="e.g EC4M 7RF"
                            aria-describedby="postcode-validation"/>
                        <ValidationMessage For="() => SearchModel!.Postcode" id="postcode-validation"/>
                    </div>
                </div>
                <div class="col-auto mt-1">
                    <button type="submit" class="btn btn-primary">Search</button>
                </div>
            </EditForm>
        </div>
    </div>
    
    <div id="map" class="map" role="application" aria-label="Map"></div>
}
else
{
    <p>The Find Takeaway feature requires an API key for Google Maps to be running and is not available on the website.</p>
    <p>
        To try the web application, follow the setup instructions in the
        <a href="https://github.com/zain-ahmed0/TakeawayFinder" target="_blank" rel="noopener noreferrer">README</a>
        to get the project running locally.
    </p>
}
